# ==============================================================================
# DOCSLY - ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# Path: src/.env.example
# Copy this file to .env and fill in the required values.
# ==============================================================================

# --- APPLICATION METADATA ---
APP_NAME="Docsly"
APP_VERSION="0.1"
LOG_LEVEL="INFO"

# --- FILE UPLOAD & PROCESSING ---
FILE_ALLOWED_TYPES=["application/pdf", "text/plain", "application/vnd.openxmlformats-officedocument.wordprocessingml.document"]
FILE_MAX_SIZE=10485760
FILE_DEFAULT_CHUNK_SIZE=524288
TEXT_SPLITTER_BACKEND="RECURSIVE" # Options: RECURSIVE, NLTK


# ========================= Database Config =========================
# MongoDB (keeping for reference during migration)
MONGODB_USERNAME="admin"
MONGODB_PASSWORD="admin_password_here"
MONGODB_URL="mongodb://${MONGODB_USERNAME}:${MONGODB_PASSWORD}@localhost:27017/"
MONGODB_DATABASE_NAME="docsly_rag_db"

# PostgreSQL + pgvector
POSTGRES_USERNAME="docsly_user"
POSTGRES_PASSWORD="your_postgres_password_here"
POSTGRES_HOST="localhost"
POSTGRES_PORT=5432
POSTGRES_MAIN_DATABASE="docsly_db"

# ========================= LLM Config =========================
GENERATION_BACKEND="OPENAI" # Options: OPENAI, COHERE, OLLAMA, GEMINI
EMBEDDING_BACKEND="COHERE" # Options: OPENAI, COHERE, OLLAMA, GEMINI

OPENAI_API_KEY="your-openai-api-key-here"
# OPENAI_API_URL=

COHERE_API_KEY="your-cohere-api-key-here"
GEMINI_API_KEY="your-gemini-api-key-here"
OLLAMA_API_URL="http://localhost:11434"

GENERATION_MODEL_ID="gpt-3.5-turbo-0125"
EMBEDDING_MODEL_ID="embed-multilingual-light-v3.0"
EMBEDDING_MODEL_SIZE=384

INPUT_DAFAULT_MAX_CHARACTERS=1024
GENERATION_DAFAULT_MAX_TOKENS=200
GENERATION_DAFAULT_TEMPERATURE=0.1

# ========================= Vector DB Config =========================
VECTOR_DB_BACKEND="PGVECTOR" # Options: QDRANT, PGVECTOR

QDRANT_URL="http://localhost:6333"
QDRANT_API_KEY="your-qdrant-api-key-here"
VECTOR_DB_DISTANCE_METHOD="cosine"
VECTOR_DB_PGVEC_INDEX_THRESHOLD=10

# ========================= Template Configs =========================
PRIMARY_LANG="ar"
DEFAULT_LANG="en"

